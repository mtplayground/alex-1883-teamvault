# Server
HOST=0.0.0.0
PORT=8080
SELF_URL=https://alex-1883-teamvault.example.com

# PostgreSQL
DATABASE_URL=postgresql://user:password@db.example.com:5432/alex_1883_teamvault?sslmode=require
DATABASE_MAX_CONNECTIONS=5
DATABASE_CONNECTION_TIMEOUT_MS=5000

# Ideavibes auth service
MCTAI_AUTH_URL=https://auth.mctai.app
MCTAI_AUTH_APP_TOKEN=app_alex-1883-teamvault-placeholder
MCTAI_AUTH_JWKS_URL=https://auth.mctai.app/.well-known/jwks.json

# Ideavibes email service
MCTAI_EMAIL_URL=https://email.mctai.app/send
MCTAI_EMAIL_APP_TOKEN=email_alex-1883-teamvault-placeholder

# Tigris/S3-compatible document storage
S3_ENDPOINT_URL=https://fly.storage.tigris.dev
S3_REGION=auto
S3_BUCKET=alex-1883-teamvault-documents
S3_ACCESS_KEY_ID=tigris_access_key_placeholder
S3_SECRET_ACCESS_KEY=tigris_secret_key_placeholder
